# GitLab API credentials (required)
GITLAB_PRIVATE_TOKEN=your-private-token
GITLAB_BASE_URL=https://gitlab.example.com/api/v4
GITLAB_PROJECT_ID=your-project-id

# Serve mode port (optional, defaults to 3099)
# PORT=3099

# Feishu notification (optional, serve mode only)
# FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxxxx
# FEISHU_WEBHOOK_SECRET=your-signature-secret
# Optional: comma-separated Feishu open_ids to @mention in notifications
# When set, an additional @mention text message will be sent after the interactive card to trigger alert
# FEISHU_AT_USERS=ou_xxx,ou_yyy
